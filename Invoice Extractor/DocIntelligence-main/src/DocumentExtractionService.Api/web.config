<?xml version="1.0" encoding="utf-8"?>
<configuration>
  <!--
    FIX v1.3-hotfix: Azure App Service IIS request timeout.
    
    Default IIS requestTimeout is 00:03:50 (230 seconds).
    Well plan extraction can take 3-8 minutes for large documents.
    Without this override, IIS returns 502 Bad Gateway before your app
    even finishes processing — and your ExceptionHandlingMiddleware
    never sees the error.
    
    Place this file in the project root (next to Program.cs) or in
    the publish output directory.
  -->
  <system.webServer>
    <handlers>
      <add name="aspNetCore" path="*" verb="*" modules="AspNetCoreModuleV2" resourceType="Unspecified" />
    </handlers>
    <aspNetCore processPath="dotnet"
                arguments=".\DocumentExtractionService.Api.dll"
                stdoutLogEnabled="true"
                stdoutLogFile=".\logs\stdout"
                hostingModel="InProcess"
                requestTimeout="00:15:00" />
  </system.webServer>
</configuration>
