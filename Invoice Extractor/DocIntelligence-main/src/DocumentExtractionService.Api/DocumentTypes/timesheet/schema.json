{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Timesheet",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "document_type", "vendor_name", "customer_name",
    "week_ending_date", "week_start_date",
    "rig_number", "well_name", "location",
    "job_number", "po_number", "invoice_number",
    "currency", "subtotal", "tax_amount", "total_amount",
    "notes", "entries", "confidence"
  ],
  "properties": {
    "document_type": { "type": "string" },
    "vendor_name": { "type": "string" },
    "customer_name": { "type": "string" },
    "week_ending_date": { "type": "string", "description": "YYYY-MM-DD" },
    "week_start_date": { "type": "string", "description": "YYYY-MM-DD" },
    "rig_number": { "type": "string" },
    "well_name": { "type": "string" },
    "location": { "type": "string" },
    "job_number": { "type": "string" },
    "po_number": { "type": "string" },
    "invoice_number": { "type": "string" },
    "currency": { "type": "string" },
    "subtotal": { "anyOf": [{ "type": "number" }, { "type": "null" }] },
    "tax_amount": { "anyOf": [{ "type": "number" }, { "type": "null" }] },
    "total_amount": { "anyOf": [{ "type": "number" }, { "type": "null" }] },
    "notes": { "type": "string" },
    "entries": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "employee_name", "employee_title", "date",
          "hours", "charge_type", "rate", "per_diem", "amount"
        ],
        "properties": {
          "employee_name": { "type": "string" },
          "employee_title": { "type": "string" },
          "date": { "type": "string", "description": "YYYY-MM-DD" },
          "hours": { "anyOf": [{ "type": "number" }, { "type": "null" }] },
          "charge_type": { "type": "string" },
          "rate": { "anyOf": [{ "type": "number" }, { "type": "null" }] },
          "per_diem": { "anyOf": [{ "type": "number" }, { "type": "null" }] },
          "amount": { "anyOf": [{ "type": "number" }, { "type": "null" }] }
        }
      }
    },
    "confidence": {
      "type": "object",
      "additionalProperties": false,
      "required": ["vendor_name", "week_ending_date", "rig_number", "total_amount"],
      "properties": {
        "vendor_name": { "type": "number" },
        "week_ending_date": { "type": "number" },
        "rig_number": { "type": "number" },
        "total_amount": { "type": "number" }
      }
    }
  }
}
